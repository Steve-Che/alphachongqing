generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ResidenceType {
  SHOP
  APARTMENT
}

enum ShopSlotStatus {
  VACANT
  OCCUPIED
}

enum RoomType {
  FRONT_HALL
  LEFT_WING
  RIGHT_WING
  MAIN_HALL
  BACK_GARDEN
  SIDE_ROOM
}

enum PostType {
  ARTICLE
  MOMENT
}

enum NotificationType {
  COMMENT
  REPLY
  FOLLOW
  LIKE
  MESSAGE
}

enum PublicVenueTier {
  FLAGSHIP
  COMMUNITY
}

enum PublicVenueType {
  LIBRARY
  CONCERT_HALL
  GALLERY
  TEAHOUSE
  SQUARE
  COMMUNITY_HALL
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  username       String         @unique
  passwordHash   String
  displayName    String?
  bio            String?
  avatarUrl      String?
  role           UserRole       @default(USER)
  residenceType  ResidenceType?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  shop           Shop?
  apartmentUnit  ApartmentUnit?
  posts          Post[]
  inviteCodes    InviteCode[]
  imageAssets    ImageAsset[]
  guestbookEntries GuestbookEntry[]
  streetMessages StreetMessage[]
  passwordResetTokens PasswordResetToken[]
  comments         Comment[]
  following        Follow[]         @relation("Following")
  followers        Follow[]         @relation("Followers")
  notifications    Notification[]   @relation("Notifications")
  notificationActs Notification[]   @relation("NotificationActors")
  likes            Like[]
  bookmarks        Bookmark[]
  chiefOfStreets   Street[]         @relation("StreetServiceChief")
  conversationParticipants ConversationParticipant[]
  directMessages   DirectMessage[]
  venueMessages    VenueMessage[]
  publicEvents     PublicEvent[]
  publicEventRsvps PublicEventRsvp[]

  @@index([username])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  revoked     Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([code])
}

model District {
  id               String   @id @default(cuid())
  slug             String   @unique
  nameZh           String
  summary          String?
  mapX             Float
  mapZ             Float
  elevation        Float    @default(0)
  color            String   @default("#8B7355")
  boundaryPolygon  Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  streets Street[]

  @@index([slug])
}

model Street {
  id             String    @id @default(cuid())
  slug           String    @unique
  nameZh         String
  summary        String?
  districtId     String
  sortOrder      Int       @default(0)
  serviceChiefId String?
  chiefSince     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  district           District            @relation(fields: [districtId], references: [id], onDelete: Cascade)
  serviceChief       User?               @relation("StreetServiceChief", fields: [serviceChiefId], references: [id], onDelete: SetNull)
  shopSlots          ShopSlot[]
  apartmentBuildings ApartmentBuilding[]
  streetMessages     StreetMessage[]
  posts              Post[]

  @@index([districtId])
  @@index([slug])
  @@index([serviceChiefId])
}

model ShopSlot {
  id        String         @id @default(cuid())
  streetId  String
  slotIndex Int
  isCenter  Boolean        @default(false)
  status    ShopSlotStatus @default(VACANT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  street Street @relation(fields: [streetId], references: [id], onDelete: Cascade)
  shop   Shop?

  @@unique([streetId, slotIndex])
  @@index([streetId, status])
}

model Shop {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String?
  coverUrl    String?
  shopSlotId  String   @unique
  ownerId     String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shopSlot         ShopSlot         @relation(fields: [shopSlotId], references: [id])
  owner            User             @relation(fields: [ownerId], references: [id])
  rooms            ShopRoom[]
  guestbookEntries GuestbookEntry[]

  @@index([slug])
}

model ShopRoom {
  id          String   @id @default(cuid())
  shopId      String
  roomType    RoomType
  displayName String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  roomContents RoomContent[]

  @@unique([shopId, roomType])
  @@index([shopId])
}

model RoomContent {
  id        String   @id @default(cuid())
  shopRoomId String
  postId    String?
  text      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopRoom ShopRoom @relation(fields: [shopRoomId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([shopRoomId])
}

model ApartmentBuilding {
  id             String   @id @default(cuid())
  streetId       String
  buildingNumber Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  street Street          @relation(fields: [streetId], references: [id], onDelete: Cascade)
  units  ApartmentUnit[]

  @@unique([streetId, buildingNumber])
  @@index([streetId])
}

model ApartmentUnit {
  id         String   @id @default(cuid())
  buildingId String
  unitNumber Int
  residentId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building ApartmentBuilding @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  resident User?             @relation(fields: [residentId], references: [id])

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
}

model Post {
  id             String   @id @default(cuid())
  type           PostType
  title          String?
  body           String
  coverUrl       String?
  authorId       String
  streetId       String?
  publicVenueId  String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  street       Street?       @relation(fields: [streetId], references: [id], onDelete: SetNull)
  publicVenue  PublicVenue?  @relation(fields: [publicVenueId], references: [id], onDelete: SetNull)
  images       ImageAsset[]
  roomContents RoomContent[]
  comments     Comment[]
  likes        Like[]
  bookmarks    Bookmark[]

  @@index([authorId, type])
  @@index([createdAt])
  @@index([streetId, createdAt])
  @@index([publicVenueId, createdAt])
}

model ImageAsset {
  id        String   @id @default(cuid())
  url       String
  userId    String
  postId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  shopId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([shopId])
}

model StreetMessage {
  id         String   @id @default(cuid())
  streetId   String
  authorId   String
  content    String
  archived   Boolean  @default(false)
  isPinned   Boolean  @default(false)
  isOfficial Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  street   Street    @relation(fields: [streetId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([streetId, createdAt])
  @@index([streetId, isPinned])
}

model Comment {
  id               String   @id @default(cuid())
  authorId         String
  body             String
  parentId         String?
  postId           String?
  guestbookEntryId String?
  streetMessageId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent         Comment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]       @relation("CommentReplies")
  post           Post?           @relation(fields: [postId], references: [id], onDelete: Cascade)
  guestbookEntry GuestbookEntry? @relation(fields: [guestbookEntryId], references: [id], onDelete: Cascade)
  streetMessage  StreetMessage?  @relation(fields: [streetMessageId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([guestbookEntryId, createdAt])
  @@index([streetMessageId, createdAt])
  @@index([parentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  actorId   String
  href      String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user  User @relation("Notifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationActors", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Bookmark {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@index([userId, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]

  @@index([updatedAt])
}

model ConversationParticipant {
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model PublicVenue {
  id           String          @id @default(cuid())
  slug         String          @unique
  nameZh       String
  summary      String?
  coverUrl     String?
  tier         PublicVenueTier
  type         PublicVenueType
  districtSlug String
  mapX         Float
  mapZ         Float
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  messages     VenueMessage[]
  posts        Post[]
  events       PublicEvent[]
  libraryBooks LibraryBook[]

  @@index([slug])
  @@index([districtSlug])
  @@index([tier, sortOrder])
}

model VenueMessage {
  id        String   @id @default(cuid())
  venueId   String
  authorId  String
  content   String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue  PublicVenue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

model PublicEvent {
  id          String    @id @default(cuid())
  venueId     String
  title       String
  summary     String
  body        String?
  startsAt    DateTime
  endsAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  venue     PublicVenue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdBy User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  rsvps     PublicEventRsvp[]

  @@index([venueId, startsAt])
}

model PublicEventRsvp {
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event PublicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
}

model LibraryBook {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  author      String
  language    String   @default("zh")
  source      String
  sourceUrl   String?
  contentPath String
  venueId     String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue PublicVenue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, sortOrder])
}
