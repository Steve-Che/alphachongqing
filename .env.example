# PostgreSQL (Neon on Vercel)
DATABASE_URL="postgresql://user:password@host:5432/alphachongqing?sslmode=verify-full"
# Prisma 直连（迁移用，Neon 控制台提供）
# DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/alphachongqing?sslmode=verify-full"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# 找回密码邮件（生产环境推荐配置 Resend）
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="阿尔法重庆 <noreply@yourdomain.com>"

# Vercel Blob (image uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
BLOB_STORE_ID="store_xxx"

# 速率限制（生产推荐 Upstash Redis）
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"
